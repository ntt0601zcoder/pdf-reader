# =============================================================================
# Google Drive integration (frontend-only OAuth — no backend)
# =============================================================================
# Create these in Google Cloud Console (see README.md → "Google Cloud setup").
# Copy this file to ".env" (or ".env.local") and fill in your own values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# OAuth 2.0 Client ID (type: Web application).
# Authorized JavaScript origins must include: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# API key (used by the Google Picker as developerKey).
VITE_GOOGLE_API_KEY=your-api-key

# Optional: the numeric project number (Picker App ID). Often the leading
# digits of your client id. Leave blank if unsure — the app falls back to
# deriving it from the client id.
VITE_GOOGLE_APP_ID=
